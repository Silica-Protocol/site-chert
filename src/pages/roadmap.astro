---
import Layout from '../layouts/Layout.astro';

const liveItems = [
  {
    title: 'Chert website',
    description: 'User-focused site for the Chert currency experience and ecosystem entry points.',
    href: '/',
    label: 'You are here'
  },
  {
    title: 'Silica Protocol website',
    description: 'Technical protocol site with architecture documentation and developer surfaces.',
    href: 'https://silicaprotocol.network',
    label: 'Visit'
  },
  {
    title: 'Blog and updates',
    description: 'User-focused guides and project updates published as content is ready.',
    href: '/blog',
    label: 'Read'
  },
  {
    title: 'GitHub repositories',
    description: 'Open-source protocol code available for developers and contributors.',
    href: 'https://github.com/Silica-Protocol',
    label: 'Explore'
  },
  {
    title: 'Community channels',
    description: 'Discord and X for announcements, discussion, and community participation.',
    href: 'https://discord.gg/silica',
    label: 'Discord'
  }
];

const comingSoonItems = [
  {
    title: 'Public testnet',
    description: 'Testnet with faucet, block explorer, and documentation for early users to test transactions.'
  },
  {
    title: 'CLI wallet (testnet)',
    description: 'Command-line wallet for developers and power users to interact with the testnet.'
  },
  {
    title: 'API and RPC surfaces',
    description: 'Public API endpoints for network interaction, health status, and developer tooling.'
  }
];

const plannedItems = [
  {
    title: 'Web, desktop, and mobile wallets',
    description: 'User-friendly wallets for all platforms.'
  },
  {
    title: 'Developer SDK',
    description: 'Integration tools for builders creating Chert-powered applications.'
  },
  {
    title: 'Testnet maturity',
    description: 'Stability improvements, testing, and transparent status communications.'
  },
  {
    title: 'Network launch',
    description: 'Mainnet deployment, security audits, and ecosystem activation.'
  }
];
---

<Layout title="Roadmap — Chert" description="Track what is live, what is coming soon, and what is planned for the Chert network and ecosystem.">
  <section class="relative min-h-[60vh] flex items-center justify-center overflow-hidden pt-24">
    <div class="absolute inset-0 bg-void">
      <div class="absolute inset-0 grid-pattern opacity-20"></div>
      <div class="absolute top-1/3 left-1/4 w-[500px] h-[500px] rounded-full bg-quantum/10 blur-[150px]"></div>
      <div class="absolute bottom-1/4 right-1/4 w-[400px] h-[400px] rounded-full bg-silica/10 blur-[120px]"></div>
    </div>

    <div class="relative z-10 max-w-[1600px] mx-auto px-6 lg:px-12 py-20 text-center">
      <span class="text-quantum font-display text-sm font-semibold tracking-widest uppercase">Roadmap</span>
      <h1 class="font-display text-4xl md:text-6xl lg:text-7xl font-bold text-snow mt-4 mb-6">
        What is live, what is next,
        <span class="gradient-text">and what is planned</span>
      </h1>
      <p class="max-w-3xl mx-auto text-xl text-silver leading-relaxed">
        This page separates shipped work from coming-soon priorities and longer-term plans. Timelines are flexible and phases are sequential.
      </p>
    </div>
  </section>

  <!-- Currently Live -->
  <section class="py-32 bg-obsidian relative overflow-hidden" id="live">
    <div class="absolute inset-0 grid-pattern opacity-10"></div>

    <div class="relative max-w-[1600px] mx-auto px-6 lg:px-12">
      <div class="text-center mb-16">
        <div class="inline-flex items-center space-x-2 mb-4">
          <span class="w-2 h-2 rounded-full bg-aurora"></span>
          <span class="text-aurora font-display text-sm font-semibold tracking-widest uppercase">Currently live</span>
        </div>
        <h2 class="font-display text-3xl md:text-5xl font-bold text-snow mt-2 mb-6">
          Where we are now
        </h2>
        <p class="max-w-3xl mx-auto text-silver text-lg">
          The foundation is set. These surfaces are publicly accessible today.
        </p>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
        {liveItems.map((item) => (
          <article class="glass rounded-2xl p-8 h-full border border-aurora/20">
            <h3 class="font-display text-xl font-bold text-snow mb-3">{item.title}</h3>
            <p class="text-silver leading-relaxed mb-4">{item.description}</p>
            <a href={item.href} class="text-quantum text-sm font-display font-semibold hover:text-quantum-bright transition-colors">
              {item.label} →
            </a>
          </article>
        ))}
      </div>
    </div>
  </section>

  <!-- Coming Soon -->
  <section class="py-32 bg-void relative overflow-hidden" id="coming-soon">
    <div class="absolute top-1/4 left-1/4 w-[400px] h-[400px] bg-silica/10 blur-[150px]"></div>

    <div class="relative max-w-[1600px] mx-auto px-6 lg:px-12">
      <div class="text-center mb-16">
        <div class="inline-flex items-center space-x-2 mb-4">
          <span class="w-2 h-2 rounded-full bg-silica-bright"></span>
          <span class="text-silica-bright font-display text-sm font-semibold tracking-widest uppercase">Coming soon</span>
        </div>
        <h2 class="font-display text-3xl md:text-5xl font-bold text-snow mt-2 mb-6">
          What is next
        </h2>
        <p class="max-w-3xl mx-auto text-silver text-lg">
          Immediate priorities for the network and ecosystem.
        </p>
      </div>

      <div class="max-w-3xl mx-auto space-y-6">
        {comingSoonItems.map((item) => (
          <article class="glass rounded-2xl p-8 border border-silica/20">
            <h3 class="font-display text-xl font-bold text-snow mb-3">{item.title}</h3>
            <p class="text-silver leading-relaxed">{item.description}</p>
          </article>
        ))}
      </div>
    </div>
  </section>

  <!-- Planned -->
  <section class="py-32 bg-obsidian relative overflow-hidden" id="planned">
    <div class="absolute inset-0 grid-pattern opacity-10"></div>

    <div class="relative max-w-[1600px] mx-auto px-6 lg:px-12">
      <div class="text-center mb-16">
        <div class="inline-flex items-center space-x-2 mb-4">
          <span class="w-2 h-2 rounded-full bg-quantum"></span>
          <span class="text-quantum font-display text-sm font-semibold tracking-widest uppercase">Planned</span>
        </div>
        <h2 class="font-display text-3xl md:text-5xl font-bold text-snow mt-2 mb-6">
          The road ahead
        </h2>
        <p class="max-w-3xl mx-auto text-silver text-lg">
          Phases are sequential but timelines are flexible. These items represent the direction, not firm delivery dates.
        </p>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-2 xl:grid-cols-4 gap-6">
        {plannedItems.map((item) => (
          <article class="glass rounded-2xl p-8 h-full">
            <h3 class="font-display text-xl font-bold text-snow mb-3">{item.title}</h3>
            <p class="text-silver leading-relaxed">{item.description}</p>
          </article>
        ))}
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="py-32 bg-void relative overflow-hidden">
    <div class="absolute inset-0">
      <div class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 w-[800px] h-[400px] bg-gradient-to-r from-quantum/10 via-silica/10 to-nebula/10 blur-[150px] rounded-full"></div>
    </div>

    <div class="relative max-w-4xl mx-auto px-6 lg:px-12 text-center">
      <h2 class="font-display text-3xl md:text-5xl font-bold text-snow mb-6">
        Want more detail on protocol progress?
      </h2>
      <p class="text-xl text-silver leading-relaxed mb-12">
        The protocol-level roadmap, including architecture milestones and subsystem status, lives on the Silica Protocol site.
      </p>

      <div class="flex flex-col sm:flex-row items-center justify-center gap-4">
        <a href="https://silicaprotocol.network" class="btn-quantum btn-premium">Silica Protocol</a>
        <a href="https://github.com/Silica-Protocol" class="btn-ghost btn-premium">GitHub</a>
      </div>
    </div>
  </section>
</Layout>

<style>
  .glass {
    background: rgba(26, 26, 36, 0.6);
    backdrop-filter: blur(20px);
    -webkit-backdrop-filter: blur(20px);
    border: 1px solid rgba(255, 255, 255, 0.05);
  }

  .grid-pattern {
    background-image: 
      linear-gradient(rgba(255,255,255,0.02) 1px, transparent 1px),
      linear-gradient(90deg, rgba(255,255,255,0.02) 1px, transparent 1px);
    background-size: 60px 60px;
  }

  .gradient-text {
    background: linear-gradient(135deg, #fbbf24, #f59e0b, #3b82f6, #8b5cf6, #fbbf24);
    background-size: 400% 400%;
    -webkit-background-clip: text;
    background-clip: text;
    -webkit-text-fill-color: transparent;
    animation: gradientShift 8s ease infinite;
  }

  @keyframes gradientShift {
    0%, 100% { background-position: 0% 50%; }
    50% { background-position: 100% 50%; }
  }

  .btn-premium {
    position: relative;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    padding: 1rem 2.5rem;
    font-family: 'Space Grotesk', sans-serif;
    font-weight: 600;
    font-size: 0.9rem;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    border: none;
    border-radius: 0;
    cursor: pointer;
    overflow: hidden;
    transition: all 0.4s cubic-bezier(0.4, 0, 0.2, 1);
  }

  .btn-quantum {
    background: linear-gradient(135deg, #fbbf24 0%, #f59e0b 50%, #d97706 100%);
    color: #0a0a0f;
  }

  .btn-quantum:hover {
    transform: translateY(-2px);
    box-shadow: 0 10px 40px rgba(251, 191, 36, 0.4);
  }

  .btn-ghost {
    background: transparent;
    color: #e8e8f0;
    border: 1px solid rgba(255, 255, 255, 0.2);
  }

  .btn-ghost:hover {
    background: rgba(255, 255, 255, 0.05);
    border-color: rgba(255, 255, 255, 0.4);
    transform: translateY(-2px);
  }
</style>
