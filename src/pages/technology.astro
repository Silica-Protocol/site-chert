---
import Layout from '../layouts/Layout.astro';

const pillars = [
  {
    title: 'Fast feedback',
    description:
      'You should know quickly that your transfer is on its way, not wonder whether the button worked.'
  },
  {
    title: 'Simple money UX',
    description:
      'Chert aims for a clean wallet and explorer experience instead of asking normal users to learn protocol trivia.'
  },
  {
    title: 'Low-fee friendly design',
    description:
      'The goal is everyday movement and micropayment-sized activity, not only expensive transactions reserved for power users.'
  },
  {
    title: 'Meaningful participation',
    description:
      'The network story includes useful work, so participation can point toward public-value computation instead of waste.'
  }
];

const flowCards = [
  {
    title: 'Send',
    description: 'Open the wallet, submit a transfer, and get immediate feedback instead of mystery.'
  },
  {
    title: 'See it pending',
    description: 'Pending is the fast user-facing signal that your activity has been picked up and is moving through the system.'
  },
  {
    title: 'Settle cleanly',
    description: 'The protocol finalizes the result after that, which is where the deeper mechanics belong on the Silica site.'
  }
];

const trustCards = [
  {
    title: 'Post-quantum ready',
    description:
      'Chert inherits a protocol stack that is designed with post-quantum readiness in mind, so the security story is not stuck in the past.'
  },
  {
    title: 'Useful work, explained simply',
    description:
      'Silica uses Proof of Useful Work (PoUW). NUW is one class of participation inside that broader useful-work system.'
  },
  {
    title: 'Silica handles the deep details',
    description:
      'Alluvium, Tephra, Crystallite, Lithification, and Cali belong on the protocol site when you want architecture, operator, or API depth.'
  }
];
---

<Layout title="Why Chert — Fast, simple, useful money" description="Why Chert exists: fast feedback, simple payments, low-fee friendliness, post-quantum readiness, and meaningful participation powered by Silica Protocol.">
  <section class="relative min-h-[60vh] flex items-center justify-center overflow-hidden pt-24">
    <div class="absolute inset-0 bg-void">
      <div class="absolute inset-0 grid-pattern opacity-20"></div>
      <div class="absolute top-1/3 left-1/4 w-[600px] h-[600px] rounded-full bg-silica/10 blur-[150px]"></div>
      <div class="absolute bottom-1/4 right-1/4 w-[400px] h-[400px] rounded-full bg-quantum/10 blur-[120px]"></div>
    </div>

    <div class="relative z-10 max-w-[1600px] mx-auto px-6 lg:px-12 py-20 text-center">
      <span class="text-quantum font-display text-sm font-semibold tracking-widest uppercase">Why Chert</span>
      <h1 class="font-display text-4xl md:text-6xl lg:text-7xl font-bold text-snow mt-4 mb-6">
        Money should feel
        <span class="gradient-text">faster, clearer, and lighter</span>
      </h1>
      <p class="max-w-3xl mx-auto text-xl text-silver leading-relaxed">
        Chert is meant to make the user experience obvious: send value, see it move quickly, pay sensible fees, and know the system below you is built for the long haul.
      </p>
    </div>
  </section>

  <section class="py-32 bg-obsidian relative overflow-hidden" id="pillars">
    <div class="absolute inset-0 grid-pattern opacity-10"></div>

    <div class="relative max-w-[1600px] mx-auto px-6 lg:px-12">
      <div class="text-center mb-16">
        <span class="text-silica-bright font-display text-sm font-semibold tracking-widest uppercase">Benefits first</span>
        <h2 class="font-display text-3xl md:text-5xl font-bold text-snow mt-4 mb-6">
          The point is not more jargon.
          <span class="gradient-text">The point is better money UX.</span>
        </h2>
        <p class="max-w-3xl mx-auto text-silver text-lg">
          This page stays at the user-benefit level on purpose. If you want the full protocol machinery, that belongs on <a href="https://silicaprotocol.network" class="text-silica-bright hover:text-silica">Silica Protocol</a>.
        </p>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-2 xl:grid-cols-4 gap-6">
        {pillars.map((pillar) => (
          <article class="glass rounded-2xl p-8 h-full">
            <h3 class="font-display text-2xl font-bold text-snow mb-4">{pillar.title}</h3>
            <p class="text-silver leading-relaxed">{pillar.description}</p>
          </article>
        ))}
      </div>
    </div>
  </section>

  <section class="py-32 bg-void relative overflow-hidden" id="how-it-feels">
    <div class="absolute top-1/3 right-1/4 w-[500px] h-[500px] bg-nebula/10 blur-[150px]"></div>

    <div class="relative max-w-[1600px] mx-auto px-6 lg:px-12">
      <div class="grid grid-cols-1 lg:grid-cols-[0.95fr_1.05fr] gap-12 items-start">
        <div>
          <span class="text-nebula-bright font-display text-sm font-semibold tracking-widest uppercase">Pending vs settlement</span>
          <h2 class="font-display text-3xl md:text-5xl font-bold text-snow mt-4 mb-6">
            Fast feedback matters because waiting feels broken.
          </h2>
          <p class="text-silver text-lg leading-relaxed mb-6">
            Chert should feel responsive. The user-facing explanation is simple: you submit a transfer, see it picked up quickly, and then let the protocol settle it properly behind the scenes.
          </p>
          <p class="text-silver text-lg leading-relaxed">
            That distinction helps users without dumping architecture names on them above the fold. It is enough to know that <span class="text-snow">pending is fast feedback</span> and <span class="text-snow">settlement is the protocol completing the job</span>.
          </p>
        </div>

        <div class="space-y-4">
          {flowCards.map((card, index) => (
            <div class="glass-light rounded-2xl p-6 flex gap-4 items-start">
              <div class="w-10 h-10 rounded-full bg-white/5 border border-white/10 flex items-center justify-center flex-shrink-0 text-quantum font-display font-bold">
                {index + 1}
              </div>
              <div>
                <h3 class="font-display text-2xl font-bold text-snow mb-2">{card.title}</h3>
                <p class="text-silver leading-relaxed">{card.description}</p>
              </div>
            </div>
          ))}
        </div>
      </div>
    </div>
  </section>

  <section class="py-32 bg-obsidian relative overflow-hidden" id="trust">
    <div class="absolute inset-0 grid-pattern opacity-10"></div>

    <div class="relative max-w-[1600px] mx-auto px-6 lg:px-12">
      <div class="text-center mb-16">
        <span class="text-aurora font-display text-sm font-semibold tracking-widest uppercase">Why it is different</span>
        <h2 class="font-display text-3xl md:text-5xl font-bold text-snow mt-4 mb-6">
          The user story is backed by a system that takes
          <span class="gradient-text">security and useful work seriously</span>
        </h2>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
        {trustCards.map((card) => (
          <article class="glass rounded-2xl p-8 h-full">
            <h3 class="font-display text-2xl font-bold text-snow mb-4">{card.title}</h3>
            <p class="text-silver leading-relaxed">{card.description}</p>
          </article>
        ))}
      </div>
    </div>
  </section>

  <section class="py-32 bg-void relative overflow-hidden" id="route-out">
    <div class="absolute inset-0">
      <div class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 w-[800px] h-[400px] bg-gradient-to-r from-quantum/10 via-silica/10 to-nebula/10 blur-[150px] rounded-full"></div>
    </div>

    <div class="relative max-w-4xl mx-auto px-6 lg:px-12 text-center">
      <h2 class="font-display text-3xl md:text-5xl font-bold text-snow mb-6">
        Want the deeper technical story?
      </h2>
      <p class="text-xl text-silver leading-relaxed mb-12">
        Chert keeps the explanation benefits-first. For architecture, APIs, SDKs, contracts, nodes, and research, go straight to the protocol site.
      </p>

      <div class="flex flex-col sm:flex-row items-center justify-center gap-4">
        <a href="https://wallet.chert.cash" class="btn-quantum btn-premium">Open Wallet</a>
        <a href="https://silicaprotocol.network" class="btn-ghost btn-premium">Silica Protocol</a>
      </div>
    </div>
  </section>
</Layout>

<style>
  .glass-light {
    background: rgba(255, 255, 255, 0.03);
    backdrop-filter: blur(10px);
    -webkit-backdrop-filter: blur(10px);
    border: 1px solid rgba(255, 255, 255, 0.08);
  }

  .glass {
    background: rgba(26, 26, 36, 0.6);
    backdrop-filter: blur(20px);
    -webkit-backdrop-filter: blur(20px);
    border: 1px solid rgba(255, 255, 255, 0.05);
  }

  .grid-pattern {
    background-image: 
      linear-gradient(rgba(255,255,255,0.02) 1px, transparent 1px),
      linear-gradient(90deg, rgba(255,255,255,0.02) 1px, transparent 1px);
    background-size: 60px 60px;
  }

  .gradient-text {
    background: linear-gradient(135deg, #fbbf24, #f59e0b, #3b82f6, #8b5cf6, #fbbf24);
    background-size: 400% 400%;
    -webkit-background-clip: text;
    background-clip: text;
    -webkit-text-fill-color: transparent;
    animation: gradientShift 8s ease infinite;
  }

  @keyframes gradientShift {
    0%, 100% { background-position: 0% 50%; }
    50% { background-position: 100% 50%; }
  }

  .btn-premium {
    position: relative;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    padding: 1rem 2.5rem;
    font-family: 'Space Grotesk', sans-serif;
    font-weight: 600;
    font-size: 0.9rem;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    border: none;
    border-radius: 0;
    cursor: pointer;
    overflow: hidden;
    transition: all 0.4s cubic-bezier(0.4, 0, 0.2, 1);
  }

  .btn-quantum {
    background: linear-gradient(135deg, #fbbf24 0%, #f59e0b 50%, #d97706 100%);
    color: #0a0a0f;
  }

  .btn-quantum:hover {
    transform: translateY(-2px);
    box-shadow: 0 10px 40px rgba(251, 191, 36, 0.4);
  }

  .btn-ghost {
    background: transparent;
    color: #e8e8f0;
    border: 1px solid rgba(255, 255, 255, 0.2);
  }

  .btn-ghost:hover {
    background: rgba(255, 255, 255, 0.05);
    border-color: rgba(255, 255, 255, 0.4);
    transform: translateY(-2px);
  }
</style>
