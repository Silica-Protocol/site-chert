];

const actionCards = [
  {
    title: 'Open the wallet',
    description: 'Get to the user-facing wallet experience quickly.',
    href: 'https://wallet.chert.cash',
    label: 'Go to wallet',
    accent: 'text-quantum'
  },
  {
    title: 'Track activity',
    description: 'Use the explorer to follow transactions and addresses.',
    href: 'https://explorer.chert.cash',
    label: 'Open explorer',
    accent: 'text-silica-bright'
  },
  {
    title: 'See what is live',
    description: 'The roadmap separates shipped, testnet, in-progress, and planned work.',
    href: '/roadmap',
    label: 'Read the roadmap',
    accent: 'text-aurora'
  },
  {
    title: 'Learn the deeper system',
    description: 'Need architecture, APIs, or operator detail? That lives on the protocol site.',
    href: 'https://silicaprotocol.network',
    label: 'Visit Silica Protocol',
    accent: 'text-nebula-bright'
  }
];

const trustCards = [
  {
    title: 'Powered by Silica Protocol',
    description:
      'Chert is the user-facing currency experience. Silica Protocol is the technical system underneath it.'
  },
  {
    title: 'Real status belongs on real surfaces',
    description:
