---
import Layout from '../layouts/Layout.astro';

const participationFlow = [
  {
    step: '1',
    title: 'Choose a path',
    description: 'Use the wallet, follow activity in the explorer, or learn how meaningful participation works.'
  },
  {
    step: '2',
    title: 'Understand the model',
    description: 'Silica uses Proof of Useful Work (PoUW), and different useful-work programs sit inside that broader system.'
  },
  {
    step: '3',
    title: 'Track rollout honestly',
    description: 'Program status belongs on roadmap, health, and protocol surfaces—not inside invented dashboard counters.'
  }
];

const workloadCards = [
  {
    label: 'PoUW class',
    title: 'NUW',
    description: 'Network Utility Work is one category of participation inside PoUW. It is not the parent mechanism name.'
  },
  {
    label: 'Workload category',
    title: 'BOINC-backed workloads',
    description: 'A useful-work family the protocol can support as public programs and verification surfaces are rolled out.'
  },
  {
    label: 'Workload category',
    title: 'Folding@Home workloads',
    description: 'Another useful-work family that fits the PoUW model when program availability and validation rules are published.'
  },
  {
    label: 'Future category',
    title: 'Additional scientific and AI tasks',
    description: 'Other validated public-value workloads can live here over time, but they should be labeled clearly as live, planned, or research.'
  }
];

const surfaceCards = [
  {
    title: 'Wallet',
    description: 'The fastest path into the user-facing Chert experience.',
    href: 'https://wallet.chert.cash',
    label: 'Open wallet'
  },
  {
    title: 'Explorer',
    description: 'Track transfers, addresses, and activity from the Chert-facing explorer surface.',
    href: 'https://explorer.chert.cash',
    label: 'Open explorer'
  },
  {
    title: 'Protocol docs',
    description: 'Need APIs, SDKs, contracts, or node detail? That belongs on Silica Protocol.',
    href: 'https://silicaprotocol.network/developers',
    label: 'Go to docs'
  },
  {
    title: 'API health',
    description: 'Use the real health endpoint when you want current network status rather than placeholder metrics.',
    href: 'https://api.silicaprotocol.network/health',
    label: 'View health'
  }
];
---

<Layout title="Ecosystem — Chert" description="Explore the Chert ecosystem: wallet and explorer access, useful-work participation categories, and the route into Silica Protocol for deeper developer and operator surfaces.">
  <section class="relative min-h-[60vh] flex items-center justify-center overflow-hidden pt-24">
    <div class="absolute inset-0 bg-void">
      <div class="absolute inset-0 grid-pattern opacity-20"></div>
      <div class="absolute top-1/4 left-1/3 w-[500px] h-[500px] rounded-full bg-quantum/10 blur-[150px]"></div>
      <div class="absolute bottom-1/3 right-1/4 w-[400px] h-[400px] rounded-full bg-silica/10 blur-[120px]"></div>
    </div>

    <div class="relative z-10 max-w-[1600px] mx-auto px-6 lg:px-12 py-20 text-center">
      <span class="text-silica-bright font-display text-sm font-semibold tracking-widest uppercase">Ecosystem</span>
      <h1 class="font-display text-4xl md:text-6xl lg:text-7xl font-bold text-snow mt-4 mb-6">
        Wallets, explorers, and
        <span class="gradient-text">participation that means something</span>
      </h1>
      <p class="max-w-3xl mx-auto text-xl text-silver leading-relaxed">
        The Chert ecosystem is not just a token page. It is the place to route users into the wallet, the explorer, and a plain-English explanation of useful-work participation.
      </p>
    </div>
  </section>

  <section class="py-32 bg-obsidian relative overflow-hidden" id="participation">
    <div class="absolute inset-0 grid-pattern opacity-10"></div>

    <div class="relative max-w-[1600px] mx-auto px-6 lg:px-12">
      <div class="text-center mb-16">
        <span class="text-quantum font-display text-sm font-semibold tracking-widest uppercase">Meaningful participation</span>
        <h2 class="font-display text-3xl md:text-5xl font-bold text-snow mt-4 mb-6">
          Useful work should be a first-class part of the ecosystem.
        </h2>
        <p class="max-w-3xl mx-auto text-silver text-lg">
          On Chert, that means explaining the idea clearly without pretending there is a live partner registry or invented public telemetry when those proof surfaces are not published yet.
        </p>
      </div>

      <div class="grid grid-cols-1 lg:grid-cols-3 gap-6 mb-16">
        {participationFlow.map((item) => (
          <article class="glass rounded-2xl p-8 text-center h-full">
            <div class="w-16 h-16 mx-auto mb-6 rounded-full bg-gradient-to-br from-silica to-silica-glow flex items-center justify-center">
              <span class="font-display text-2xl font-bold text-snow">{item.step}</span>
            </div>
            <h3 class="font-display text-xl font-bold text-snow mb-3">{item.title}</h3>
            <p class="text-silver leading-relaxed">{item.description}</p>
          </article>
        ))}
      </div>

      <div class="glass-light rounded-3xl p-8 md:p-10 border border-white/10">
        <p class="text-xs uppercase tracking-[0.2em] text-silver mb-3">Terminology rule</p>
        <p class="text-silver text-lg leading-relaxed">
          <span class="text-snow">Proof of Useful Work (PoUW)</span> is the parent mechanism. <span class="text-snow">NUW</span>, BOINC-backed workloads, Folding@Home workloads, and future scientific or AI programs are categories or implementations within that broader system.
        </p>
      </div>
    </div>
  </section>

  <section class="py-32 bg-void relative overflow-hidden" id="workload-categories">
    <div class="absolute top-1/4 left-1/4 w-[400px] h-[400px] bg-nebula/10 blur-[150px]"></div>

    <div class="relative max-w-[1600px] mx-auto px-6 lg:px-12">
      <div class="text-center mb-16">
        <span class="text-nebula-bright font-display text-sm font-semibold tracking-widest uppercase">Useful-work categories</span>
        <h2 class="font-display text-3xl md:text-5xl font-bold text-snow mt-4 mb-6">
          What fits inside the model
        </h2>
        <p class="max-w-3xl mx-auto text-silver text-lg">
          These are ecosystem categories, not claims that every program is already live. Public rollout status should always be labeled clearly.
        </p>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-2 xl:grid-cols-4 gap-6">
        {workloadCards.map((card) => (
          <article class="glass rounded-2xl p-8 h-full">
            <p class="text-xs uppercase tracking-[0.2em] text-silica-bright mb-3">{card.label}</p>
            <h3 class="font-display text-2xl font-bold text-snow mb-4">{card.title}</h3>
            <p class="text-silver leading-relaxed">{card.description}</p>
          </article>
        ))}
      </div>
    </div>
  </section>

  <section class="py-32 bg-obsidian relative overflow-hidden" id="surfaces">
    <div class="absolute inset-0 grid-pattern opacity-10"></div>

    <div class="relative max-w-[1600px] mx-auto px-6 lg:px-12">
      <div class="text-center mb-16">
        <span class="text-aurora font-display text-sm font-semibold tracking-widest uppercase">What you can use</span>
        <h2 class="font-display text-3xl md:text-5xl font-bold text-snow mt-4 mb-6">
          Start with the real public surfaces.
        </h2>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-2 xl:grid-cols-4 gap-6">
        {surfaceCards.map((card) => (
          <a href={card.href} class="glass rounded-2xl p-8 hover:border-white/15 transition-all duration-300 group">
            <h3 class="font-display text-2xl font-bold text-snow mb-4">{card.title}</h3>
            <p class="text-silver leading-relaxed mb-6">{card.description}</p>
            <span class="inline-flex items-center text-quantum text-sm group-hover:translate-x-1 transition-transform">
              {card.label}
              <svg class="w-4 h-4 ml-1" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"></path></svg>
            </span>
          </a>
        ))}
      </div>
    </div>
  </section>

  <section class="py-32 bg-void relative overflow-hidden">
    <div class="absolute inset-0">
      <div class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 w-[800px] h-[400px] bg-gradient-to-r from-quantum/10 via-silica/10 to-nebula/10 blur-[150px] rounded-full"></div>
    </div>

    <div class="relative max-w-4xl mx-auto px-6 lg:px-12 text-center">
      <h2 class="font-display text-3xl md:text-5xl font-bold text-snow mb-6">
        Want the technical registry, APIs, and roadmap details?
      </h2>
      <p class="text-xl text-silver leading-relaxed mb-12">
        Chert explains the ecosystem at a user-friendly level. Silica Protocol is where the deeper builder, operator, and proof surfaces should live.
      </p>

      <div class="flex flex-col sm:flex-row items-center justify-center gap-4">
        <a href="https://wallet.chert.cash" class="btn-quantum btn-premium">Open Wallet</a>
        <a href="https://silicaprotocol.network" class="btn-ghost btn-premium">Silica Protocol</a>
      </div>
    </div>
  </section>
</Layout>

<style>
  .glass {
    background: rgba(26, 26, 36, 0.6);
    backdrop-filter: blur(20px);
    -webkit-backdrop-filter: blur(20px);
    border: 1px solid rgba(255, 255, 255, 0.05);
  }

  .grid-pattern {
    background-image: 
      linear-gradient(rgba(255,255,255,0.02) 1px, transparent 1px),
      linear-gradient(90deg, rgba(255,255,255,0.02) 1px, transparent 1px);
    background-size: 60px 60px;
  }

  .gradient-text {
    background: linear-gradient(135deg, #22c55e, #10b981, #3b82f6, #8b5cf6, #22c55e);
    background-size: 400% 400%;
    -webkit-background-clip: text;
    background-clip: text;
    -webkit-text-fill-color: transparent;
    animation: gradientShift 8s ease infinite;
  }

  @keyframes gradientShift {
    0%, 100% { background-position: 0% 50%; }
    50% { background-position: 100% 50%; }
  }

  .btn-premium {
    position: relative;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    padding: 1rem 2.5rem;
    font-family: 'Space Grotesk', sans-serif;
    font-weight: 600;
    font-size: 0.9rem;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    border: none;
    border-radius: 0;
    cursor: pointer;
    overflow: hidden;
    transition: all 0.4s cubic-bezier(0.4, 0, 0.2, 1);
  }

  .btn-quantum {
    background: linear-gradient(135deg, #fbbf24 0%, #f59e0b 50%, #d97706 100%);
    color: #0a0a0f;
  }

  .btn-quantum:hover {
    transform: translateY(-2px);
    box-shadow: 0 10px 40px rgba(251, 191, 36, 0.4);
  }

  .btn-ghost {
    background: transparent;
    color: #e8e8f0;
    border: 1px solid rgba(255, 255, 255, 0.2);
  }

  .btn-ghost:hover {
    background: rgba(255, 255, 255, 0.05);
    border-color: rgba(255, 255, 255, 0.4);
    transform: translateY(-2px);
  }
</style>
