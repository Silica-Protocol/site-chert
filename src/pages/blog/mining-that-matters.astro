const frontmatter = {
  title: 'Mining That Matters',
  description: 'How Silica makes blockchain green and socially useful. Proof of Useful Work turns energy waste into scientific progress.',
  author: 'Silica Network Team',
  date: 'December 4, 2024',
  category: 'Sustainability',
