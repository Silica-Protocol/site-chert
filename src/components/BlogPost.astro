---
// Blog Post Component for Chert Website
const { title, date, author, category, readingTime } = Astro.props;
---

<div class="bg-white rounded-xl shadow-sm overflow-hidden">
  <div class="p-6">
    <div class="flex items-center justify-between mb-4">
      <div class="flex items-center space-x-3">
        <span class="bg-chert-blue text-white text-xs font-medium px-3 py-1 rounded-full">{category}</span>
        <span class="text-sm text-gray-500">{readingTime} min read</span>
      </div>
      <div class="flex items-center space-x-2">
        <div class="w-6 h-6 bg-gradient-to-br from-chert-blue to-quantum-gold rounded-full flex items-center justify-center">
          <span class="text-xs text-white font-bold">{author.substring(0, 1)}</span>
        </div>
        <span class="text-sm text-gray-600">{author}</span>
      </div>
    </div>

    <h2 class="text-xl font-semibold text-carbon-black mb-4">{title}</h2>
    <div class="flex items-center text-sm text-gray-500 mb-4">
      <svg class="w-4 h-4 mr-1" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z"></path>
      </svg>
      <span>{date}</span>
    </div>

    <div class="prose prose-chert max-w-none">
      <slot />
    </div>
  </div>
</div>