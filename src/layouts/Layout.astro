---
// Premium Layout for Chert Website
// Inspired by high-end fintech and luxury blockchain aesthetics
interface Props {
  title?: string;
  description?: string;
}

const {
  title = 'Chert',
  description = 'Chert is the fast, simple, user-facing currency experience secured by Silica Protocol.'
} = Astro.props;
---

<!DOCTYPE html>
<html lang="en" class="scroll-smooth">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <meta name="theme-color" content="#0a0a0f" />
    
    <!-- Open Graph -->
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
    <meta property="og:image" content="/og-image.png" />
    
    <title>{title}</title>

    <!-- Favicon -->
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />

    <!-- Fonts - Premium Typography -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800;900&family=Space+Grotesk:wght@300;400;500;600;700&family=JetBrains+Mono:wght@400;500;600&display=swap" rel="stylesheet" />

    <!-- Critical CSS -->
    <style is:global>
      :root {
        --color-void: #0a0a0f;
        --color-obsidian: #111118;
        --color-graphite: #1a1a24;
        --color-slate: #252532;
        --color-ash: #3a3a4a;
        --color-silver: #8a8a9a;
        --color-pearl: #e8e8f0;
        --color-snow: #ffffff;
        
        --color-quantum: #fbbf24;
        --color-quantum-bright: #fcd34d;
        --color-quantum-glow: #f59e0b;
        
        --color-silica: #3b82f6;
        --color-silica-bright: #60a5fa;
        --color-silica-glow: #2563eb;
        
        --color-aurora: #22c55e;
        --color-aurora-bright: #4ade80;
        
        --color-nebula: #a855f7;
        --color-nebula-bright: #c084fc;
        
        --gradient-golden: linear-gradient(135deg, #fbbf24 0%, #f59e0b 50%, #d97706 100%);
        --gradient-royal: linear-gradient(135deg, #3b82f6 0%, #8b5cf6 50%, #a855f7 100%);
        --gradient-void: linear-gradient(180deg, #0a0a0f 0%, #111118 100%);
        
        --font-display: 'Space Grotesk', -apple-system, BlinkMacSystemFont, sans-serif;
        --font-body: 'Inter', -apple-system, BlinkMacSystemFont, sans-serif;
        --font-mono: 'JetBrains Mono', 'Fira Code', monospace;
      }

      * {
        margin: 0;
        padding: 0;
        box-sizing: border-box;
      }

      html {
        scroll-behavior: smooth;
        background: var(--color-void);
      }

      body {
        font-family: var(--font-body);
        background: var(--color-void);
        color: var(--color-pearl);
        line-height: 1.6;
        overflow-x: hidden;
        -webkit-font-smoothing: antialiased;
        -moz-osx-font-smoothing: grayscale;
      }

      /* Custom Scrollbar */
      ::-webkit-scrollbar {
        width: 8px;
      }

      ::-webkit-scrollbar-track {
        background: var(--color-obsidian);
      }

      ::-webkit-scrollbar-thumb {
        background: var(--color-ash);
        border-radius: 4px;
      }

      ::-webkit-scrollbar-thumb:hover {
        background: var(--color-silver);
      }

      /* Selection */
      ::selection {
        background: rgba(251, 191, 36, 0.3);
        color: var(--color-snow);
      }

      /* Glow Effects */
      .glow-quantum {
        box-shadow: 0 0 40px rgba(251, 191, 36, 0.3),
                    0 0 80px rgba(251, 191, 36, 0.1);
      }

      .glow-silica {
        box-shadow: 0 0 40px rgba(59, 130, 246, 0.3),
                    0 0 80px rgba(59, 130, 246, 0.1);
      }

      .text-glow-quantum {
        text-shadow: 0 0 20px rgba(251, 191, 36, 0.5),
                     0 0 40px rgba(251, 191, 36, 0.3);
      }

      .text-glow-silica {
        text-shadow: 0 0 20px rgba(59, 130, 246, 0.5),
                     0 0 40px rgba(59, 130, 246, 0.3);
      }

      /* Animated Gradient Text */
      .gradient-text {
        background: linear-gradient(135deg, #fbbf24, #f59e0b, #3b82f6, #8b5cf6, #fbbf24);
        background-size: 400% 400%;
        -webkit-background-clip: text;
        background-clip: text;
        -webkit-text-fill-color: transparent;
        animation: gradientShift 8s ease infinite;
      }

      @keyframes gradientShift {
        0%, 100% { background-position: 0% 50%; }
        50% { background-position: 100% 50%; }
      }

      /* Glass Effect */
      .glass {
        background: rgba(26, 26, 36, 0.6);
        backdrop-filter: blur(20px);
        -webkit-backdrop-filter: blur(20px);
        border: 1px solid rgba(255, 255, 255, 0.05);
      }

      .glass-light {
        background: rgba(255, 255, 255, 0.03);
        backdrop-filter: blur(10px);
        -webkit-backdrop-filter: blur(10px);
        border: 1px solid rgba(255, 255, 255, 0.08);
      }

      /* Noise Texture Overlay */
      .noise::before {
        content: '';
        position: absolute;
        top: 0;
        left: 0;
        right: 0;
        bottom: 0;
        background-image: url("data:image/svg+xml,%3Csvg viewBox='0 0 200 200' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='noiseFilter'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.9' numOctaves='4' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23noiseFilter)'/%3E%3C/svg%3E");
        opacity: 0.03;
        pointer-events: none;
        z-index: 1;
      }

      /* Premium Button */
      .btn-premium {
        position: relative;
        display: inline-flex;
        align-items: center;
        justify-content: center;
        padding: 1rem 2.5rem;
        font-family: var(--font-display);
        font-weight: 600;
        font-size: 0.9rem;
        letter-spacing: 0.1em;
        text-transform: uppercase;
        border: none;
        border-radius: 0;
        cursor: pointer;
        overflow: hidden;
        transition: all 0.4s cubic-bezier(0.4, 0, 0.2, 1);
      }

      .btn-premium::before {
        content: '';
        position: absolute;
        top: 0;
        left: -100%;
        width: 100%;
        height: 100%;
        background: linear-gradient(90deg, transparent, rgba(255,255,255,0.2), transparent);
        transition: left 0.6s ease;
      }

      .btn-premium:hover::before {
        left: 100%;
      }

      .btn-quantum {
        background: var(--gradient-golden);
        color: var(--color-void);
      }

      .btn-quantum:hover {
        transform: translateY(-2px);
        box-shadow: 0 10px 40px rgba(251, 191, 36, 0.4);
      }

      .btn-ghost {
        background: transparent;
        color: var(--color-pearl);
        border: 1px solid rgba(255, 255, 255, 0.2);
      }

      .btn-ghost:hover {
        background: rgba(255, 255, 255, 0.05);
        border-color: rgba(255, 255, 255, 0.4);
        transform: translateY(-2px);
      }

      /* Section Styling */
      .section-dark {
        background: var(--color-void);
      }

      .section-obsidian {
        background: var(--color-obsidian);
      }

      /* Divider Line */
      .divider {
        width: 100%;
        height: 1px;
        background: linear-gradient(90deg, transparent, rgba(255,255,255,0.1), transparent);
      }

      /* Grid Pattern Background */
      .grid-pattern {
        background-image: 
          linear-gradient(rgba(255,255,255,0.02) 1px, transparent 1px),
          linear-gradient(90deg, rgba(255,255,255,0.02) 1px, transparent 1px);
        background-size: 60px 60px;
      }

      /* Radial Gradient Spotlight */
      .spotlight {
        position: absolute;
        width: 800px;
        height: 800px;
        border-radius: 50%;
        background: radial-gradient(circle, rgba(251, 191, 36, 0.08) 0%, transparent 70%);
        pointer-events: none;
      }
    </style>
  </head>

  <body class="min-h-screen flex flex-col">
    <!-- Premium Navigation -->
    <nav class="fixed top-0 left-0 right-0 z-50 transition-all duration-500" id="main-nav">
      <div class="max-w-[1600px] mx-auto px-6 lg:px-12">
        <div class="flex items-center justify-between h-20 lg:h-24">
          <!-- Logo -->
          <a href="/" class="flex items-center space-x-3 group">
            <div class="relative w-10 h-10 lg:w-12 lg:h-12">
              <div class="absolute inset-0 bg-gradient-to-br from-quantum to-quantum-glow rounded-lg transform group-hover:rotate-12 transition-transform duration-500"></div>
              <div class="absolute inset-[2px] bg-void rounded-lg flex items-center justify-center">
                <span class="text-quantum font-display font-bold text-lg lg:text-xl">C</span>
              </div>
            </div>
            <span class="font-display font-bold text-xl lg:text-2xl tracking-tight text-snow">CHERT</span>
          </a>

          <!-- Desktop Navigation -->
          <div class="hidden lg:flex items-center space-x-12">
            <a href="/technology" class="nav-link">Why Chert</a>
            <a href="/ecosystem" class="nav-link">Ecosystem</a>
            <a href="/roadmap" class="nav-link">Roadmap</a>
            <a href="/blog" class="nav-link">Blog</a>
            <a href="https://silicaprotocol.network" class="nav-link text-silica-bright hover:text-silica">Silica Protocol →</a>
          </div>

          <!-- CTA Buttons -->
          <div class="hidden lg:flex items-center space-x-4">
            <a href="https://explorer.chert.cash" class="btn-ghost btn-premium text-sm">Explorer</a>
            <a href="https://wallet.chert.cash" class="btn-quantum btn-premium text-sm">Wallet</a>
          </div>

          <!-- Mobile Menu Button -->
          <button id="mobile-menu-btn" class="lg:hidden text-pearl p-2" aria-label="Menu">
            <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16"></path>
            </svg>
          </button>
        </div>
      </div>
    </nav>

    <!-- Mobile Menu -->
    <div id="mobile-menu" class="fixed inset-0 z-40 bg-void/98 backdrop-blur-xl hidden lg:hidden">
      <div class="flex flex-col items-center justify-center h-full space-y-8">
        <a href="/technology" class="text-2xl font-display text-pearl hover:text-quantum transition-colors">Why Chert</a>
        <a href="/ecosystem" class="text-2xl font-display text-pearl hover:text-quantum transition-colors">Ecosystem</a>
        <a href="/roadmap" class="text-2xl font-display text-pearl hover:text-quantum transition-colors">Roadmap</a>
        <a href="/blog" class="text-2xl font-display text-pearl hover:text-quantum transition-colors">Blog</a>
        <a href="https://silicaprotocol.network" class="text-2xl font-display text-silica-bright hover:text-silica transition-colors">Silica Protocol →</a>
        <div class="pt-8 flex flex-col space-y-4">
          <a href="https://explorer.chert.cash" class="btn-ghost btn-premium">Explorer</a>
          <a href="https://wallet.chert.cash" class="btn-quantum btn-premium">Wallet</a>
        </div>
      </div>
      <button id="mobile-menu-close" class="absolute top-6 right-6 text-pearl p-2" aria-label="Close">
        <svg class="w-8 h-8" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"></path>
        </svg>
      </button>
    </div>

    <!-- Main Content -->
    <main class="flex-grow">
      <slot />
    </main>

    <!-- Premium Footer -->
    <footer class="relative bg-obsidian border-t border-white/5">
      <!-- Footer Glow -->
      <div class="absolute bottom-0 left-1/2 -translate-x-1/2 w-[600px] h-[300px] bg-quantum/5 blur-[120px] pointer-events-none"></div>
      
      <div class="relative max-w-[1600px] mx-auto px-6 lg:px-12 py-20">
        <div class="grid grid-cols-1 lg:grid-cols-12 gap-12 lg:gap-8">
          <!-- Brand Column -->
          <div class="lg:col-span-4">
            <a href="/" class="flex items-center space-x-3 mb-6">
              <div class="relative w-10 h-10">
                <div class="absolute inset-0 bg-gradient-to-br from-quantum to-quantum-glow rounded-lg"></div>
                <div class="absolute inset-[2px] bg-obsidian rounded-lg flex items-center justify-center">
                  <span class="text-quantum font-display font-bold text-lg">C</span>
                </div>
              </div>
              <span class="font-display font-bold text-2xl tracking-tight text-snow">CHERT</span>
            </a>
            <p class="text-silver text-sm leading-relaxed mb-8 max-w-sm">
              Chert is the fast, simple, user-facing currency experience secured by Silica Protocol. Wallet, explorer, roadmap, and useful-work entry points start here.
            </p>
            <div class="flex flex-wrap gap-3">
              <a href="https://wallet.chert.cash" class="text-silver text-sm hover:text-pearl transition-colors">Wallet</a>
              <a href="https://explorer.chert.cash" class="text-silver text-sm hover:text-pearl transition-colors">Explorer</a>
              <a href="https://silicaprotocol.network" class="text-silver text-sm hover:text-pearl transition-colors">Silica Protocol</a>
              <a href="https://github.com/Silica-Protocol" class="text-silver text-sm hover:text-pearl transition-colors">GitHub</a>
            </div>
          </div>

          <!-- Navigation Links -->
          <div class="lg:col-span-2">
            <h4 class="font-display font-semibold text-snow text-sm tracking-wider mb-6">PRODUCT</h4>
            <ul class="space-y-4">
              <li><a href="https://wallet.chert.cash" class="text-silver text-sm hover:text-pearl transition-colors">Wallet</a></li>
              <li><a href="https://explorer.chert.cash" class="text-silver text-sm hover:text-pearl transition-colors">Explorer</a></li>
              <li><a href="/technology" class="text-silver text-sm hover:text-pearl transition-colors">Why Chert</a></li>
              <li><a href="/roadmap" class="text-silver text-sm hover:text-pearl transition-colors">Roadmap</a></li>
            </ul>
          </div>

          <div class="lg:col-span-2">
            <h4 class="font-display font-semibold text-snow text-sm tracking-wider mb-6">PROTOCOL</h4>
            <ul class="space-y-4">
              <li><a href="https://silicaprotocol.network" class="text-silver text-sm hover:text-pearl transition-colors">Silica Protocol</a></li>
              <li><a href="https://silicaprotocol.network/developers" class="text-silver text-sm hover:text-pearl transition-colors">Developer docs</a></li>
              <li><a href="https://api.silicaprotocol.network/health" class="text-silver text-sm hover:text-pearl transition-colors">API health</a></li>
              <li><a href="https://github.com/Silica-Protocol" class="text-silver text-sm hover:text-pearl transition-colors">GitHub</a></li>
            </ul>
          </div>

          <div class="lg:col-span-2">
            <h4 class="font-display font-semibold text-snow text-sm tracking-wider mb-6">PARTICIPATE</h4>
            <ul class="space-y-4">
              <li><a href="/ecosystem" class="text-silver text-sm hover:text-pearl transition-colors">Ecosystem</a></li>
              <li><a href="/blog/mining-that-matters" class="text-silver text-sm hover:text-pearl transition-colors">Mining that matters</a></li>
              <li><a href="/roadmap" class="text-silver text-sm hover:text-pearl transition-colors">Roadmap</a></li>
              <li><a href="https://silicaprotocol.network/technology" class="text-silver text-sm hover:text-pearl transition-colors">How the protocol works</a></li>
            </ul>
          </div>

          <div class="lg:col-span-2">
            <h4 class="font-display font-semibold text-snow text-sm tracking-wider mb-6">LEARN</h4>
            <ul class="space-y-4">
              <li><a href="/blog" class="text-silver text-sm hover:text-pearl transition-colors">Blog</a></li>
              <li><a href="/ecosystem" class="text-silver text-sm hover:text-pearl transition-colors">Ecosystem</a></li>
              <li><a href="/technology" class="text-silver text-sm hover:text-pearl transition-colors">Why Chert</a></li>
              <li><a href="/disclaimer" class="text-silver text-sm hover:text-pearl transition-colors">Disclaimer</a></li>
            </ul>
          </div>
        </div>

        <!-- Footer Bottom -->
        <div class="mt-16 pt-8 border-t border-white/5 flex flex-col lg:flex-row items-center justify-between">
          <p class="text-silver text-sm">© {new Date().getFullYear()} Chert. All rights reserved.</p>
          <div class="flex items-center space-x-8 mt-4 lg:mt-0">
            <a href="/terms" class="text-silver text-sm hover:text-pearl transition-colors">Terms</a>
            <a href="/privacy" class="text-silver text-sm hover:text-pearl transition-colors">Privacy</a>
            <a href="/disclaimer" class="text-silver text-sm hover:text-pearl transition-colors">Disclaimer</a>
          </div>
        </div>
      </div>
    </footer>

    <!-- Navigation Styles -->
    <style>
      .nav-link {
        font-family: var(--font-display);
        font-size: 0.875rem;
        font-weight: 500;
        color: var(--color-silver);
        letter-spacing: 0.02em;
        position: relative;
        transition: color 0.3s ease;
      }

      .nav-link::after {
        content: '';
        position: absolute;
        bottom: -4px;
        left: 0;
        width: 0;
        height: 1px;
        background: var(--color-quantum);
        transition: width 0.3s ease;
      }

      .nav-link:hover {
        color: var(--color-pearl);
      }

      .nav-link:hover::after {
        width: 100%;
      }

      #main-nav {
        background: transparent;
      }

      #main-nav.scrolled {
        background: rgba(10, 10, 15, 0.9);
        backdrop-filter: blur(20px);
        -webkit-backdrop-filter: blur(20px);
        border-bottom: 1px solid rgba(255, 255, 255, 0.05);
      }
    </style>

    <!-- Scripts -->
    <script>
      // Navigation scroll effect
      const nav = document.getElementById('main-nav');
      window.addEventListener('scroll', () => {
        if (window.scrollY > 50) {
          nav?.classList.add('scrolled');
        } else {
          nav?.classList.remove('scrolled');
        }
      });

      // Mobile menu toggle
      const mobileMenuBtn = document.getElementById('mobile-menu-btn');
      const mobileMenuClose = document.getElementById('mobile-menu-close');
      const mobileMenu = document.getElementById('mobile-menu');

      mobileMenuBtn?.addEventListener('click', () => {
        mobileMenu?.classList.remove('hidden');
        document.body.style.overflow = 'hidden';
      });

      mobileMenuClose?.addEventListener('click', () => {
        mobileMenu?.classList.add('hidden');
        document.body.style.overflow = '';
      });

      // Close mobile menu on link click
      mobileMenu?.querySelectorAll('a').forEach(link => {
        link.addEventListener('click', () => {
          mobileMenu?.classList.add('hidden');
          document.body.style.overflow = '';
        });
      });
    </script>
  </body>
</html>
