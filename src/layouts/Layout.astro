---
// Premium Layout for Chert Coin Website
// Inspired by high-end fintech and luxury blockchain aesthetics
interface Props {
  title?: string;
  description?: string;
}

const { title = "Chert Coin", description = "The Future of Currency. Sub-second finality. Million TPS. Post-quantum security. Mining that matters." } = Astro.props;
---

<!DOCTYPE html>
<html lang="en" class="scroll-smooth">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <meta name="theme-color" content="#0a0a0f" />
    
    <!-- Open Graph -->
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
    <meta property="og:image" content="/og-image.png" />
    
    <title>{title}</title>

    <!-- Favicon -->
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />

    <!-- Fonts - Premium Typography -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800;900&family=Space+Grotesk:wght@300;400;500;600;700&family=JetBrains+Mono:wght@400;500;600&display=swap" rel="stylesheet" />

    <!-- Critical CSS -->
    <style is:global>
      :root {
        --color-void: #0a0a0f;
        --color-obsidian: #111118;
        --color-graphite: #1a1a24;
        --color-slate: #252532;
        --color-ash: #3a3a4a;
        --color-silver: #8a8a9a;
        --color-pearl: #e8e8f0;
        --color-snow: #ffffff;
        
        --color-quantum: #fbbf24;
        --color-quantum-bright: #fcd34d;
        --color-quantum-glow: #f59e0b;
        
        --color-silica: #3b82f6;
        --color-silica-bright: #60a5fa;
        --color-silica-glow: #2563eb;
        
        --color-aurora: #22c55e;
        --color-aurora-bright: #4ade80;
        
        --color-nebula: #a855f7;
        --color-nebula-bright: #c084fc;
        
        --gradient-golden: linear-gradient(135deg, #fbbf24 0%, #f59e0b 50%, #d97706 100%);
        --gradient-royal: linear-gradient(135deg, #3b82f6 0%, #8b5cf6 50%, #a855f7 100%);
        --gradient-void: linear-gradient(180deg, #0a0a0f 0%, #111118 100%);
        
        --font-display: 'Space Grotesk', -apple-system, BlinkMacSystemFont, sans-serif;
        --font-body: 'Inter', -apple-system, BlinkMacSystemFont, sans-serif;
        --font-mono: 'JetBrains Mono', 'Fira Code', monospace;
      }

      * {
        margin: 0;
        padding: 0;
        box-sizing: border-box;
      }

      html {
        scroll-behavior: smooth;
        background: var(--color-void);
      }

      body {
        font-family: var(--font-body);
        background: var(--color-void);
        color: var(--color-pearl);
        line-height: 1.6;
        overflow-x: hidden;
        -webkit-font-smoothing: antialiased;
        -moz-osx-font-smoothing: grayscale;
      }

      /* Custom Scrollbar */
      ::-webkit-scrollbar {
        width: 8px;
      }

      ::-webkit-scrollbar-track {
        background: var(--color-obsidian);
      }

      ::-webkit-scrollbar-thumb {
        background: var(--color-ash);
        border-radius: 4px;
      }

      ::-webkit-scrollbar-thumb:hover {
        background: var(--color-silver);
      }

      /* Selection */
      ::selection {
        background: rgba(251, 191, 36, 0.3);
        color: var(--color-snow);
      }

      /* Glow Effects */
      .glow-quantum {
        box-shadow: 0 0 40px rgba(251, 191, 36, 0.3),
                    0 0 80px rgba(251, 191, 36, 0.1);
      }

      .glow-silica {
        box-shadow: 0 0 40px rgba(59, 130, 246, 0.3),
                    0 0 80px rgba(59, 130, 246, 0.1);
      }

      .text-glow-quantum {
        text-shadow: 0 0 20px rgba(251, 191, 36, 0.5),
                     0 0 40px rgba(251, 191, 36, 0.3);
      }

      .text-glow-silica {
        text-shadow: 0 0 20px rgba(59, 130, 246, 0.5),
                     0 0 40px rgba(59, 130, 246, 0.3);
      }

      /* Animated Gradient Text */
      .gradient-text {
        background: linear-gradient(135deg, #fbbf24, #f59e0b, #3b82f6, #8b5cf6, #fbbf24);
        background-size: 400% 400%;
        -webkit-background-clip: text;
        background-clip: text;
        -webkit-text-fill-color: transparent;
        animation: gradientShift 8s ease infinite;
      }

      @keyframes gradientShift {
        0%, 100% { background-position: 0% 50%; }
        50% { background-position: 100% 50%; }
      }

      /* Glass Effect */
      .glass {
        background: rgba(26, 26, 36, 0.6);
        backdrop-filter: blur(20px);
        -webkit-backdrop-filter: blur(20px);
        border: 1px solid rgba(255, 255, 255, 0.05);
      }

      .glass-light {
        background: rgba(255, 255, 255, 0.03);
        backdrop-filter: blur(10px);
        -webkit-backdrop-filter: blur(10px);
        border: 1px solid rgba(255, 255, 255, 0.08);
      }

      /* Noise Texture Overlay */
      .noise::before {
        content: '';
        position: absolute;
        top: 0;
        left: 0;
        right: 0;
        bottom: 0;
        background-image: url("data:image/svg+xml,%3Csvg viewBox='0 0 200 200' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='noiseFilter'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.9' numOctaves='4' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23noiseFilter)'/%3E%3C/svg%3E");
        opacity: 0.03;
        pointer-events: none;
        z-index: 1;
      }

      /* Premium Button */
      .btn-premium {
        position: relative;
        display: inline-flex;
        align-items: center;
        justify-content: center;
        padding: 1rem 2.5rem;
        font-family: var(--font-display);
        font-weight: 600;
        font-size: 0.9rem;
        letter-spacing: 0.1em;
        text-transform: uppercase;
        border: none;
        border-radius: 0;
        cursor: pointer;
        overflow: hidden;
        transition: all 0.4s cubic-bezier(0.4, 0, 0.2, 1);
      }

      .btn-premium::before {
        content: '';
        position: absolute;
        top: 0;
        left: -100%;
        width: 100%;
        height: 100%;
        background: linear-gradient(90deg, transparent, rgba(255,255,255,0.2), transparent);
        transition: left 0.6s ease;
      }

      .btn-premium:hover::before {
        left: 100%;
      }

      .btn-quantum {
        background: var(--gradient-golden);
        color: var(--color-void);
      }

      .btn-quantum:hover {
        transform: translateY(-2px);
        box-shadow: 0 10px 40px rgba(251, 191, 36, 0.4);
      }

      .btn-ghost {
        background: transparent;
        color: var(--color-pearl);
        border: 1px solid rgba(255, 255, 255, 0.2);
      }

      .btn-ghost:hover {
        background: rgba(255, 255, 255, 0.05);
        border-color: rgba(255, 255, 255, 0.4);
        transform: translateY(-2px);
      }

      /* Section Styling */
      .section-dark {
        background: var(--color-void);
      }

      .section-obsidian {
        background: var(--color-obsidian);
      }

      /* Divider Line */
      .divider {
        width: 100%;
        height: 1px;
        background: linear-gradient(90deg, transparent, rgba(255,255,255,0.1), transparent);
      }

      /* Grid Pattern Background */
      .grid-pattern {
        background-image: 
          linear-gradient(rgba(255,255,255,0.02) 1px, transparent 1px),
          linear-gradient(90deg, rgba(255,255,255,0.02) 1px, transparent 1px);
        background-size: 60px 60px;
      }

      /* Radial Gradient Spotlight */
      .spotlight {
        position: absolute;
        width: 800px;
        height: 800px;
        border-radius: 50%;
        background: radial-gradient(circle, rgba(251, 191, 36, 0.08) 0%, transparent 70%);
        pointer-events: none;
      }
    </style>
  </head>

  <body class="min-h-screen flex flex-col">
    <!-- Premium Navigation -->
    <nav class="fixed top-0 left-0 right-0 z-50 transition-all duration-500" id="main-nav">
      <div class="max-w-[1600px] mx-auto px-6 lg:px-12">
        <div class="flex items-center justify-between h-20 lg:h-24">
          <!-- Logo -->
          <a href="/" class="flex items-center space-x-3 group">
            <div class="relative w-10 h-10 lg:w-12 lg:h-12">
              <div class="absolute inset-0 bg-gradient-to-br from-quantum to-quantum-glow rounded-lg transform group-hover:rotate-12 transition-transform duration-500"></div>
              <div class="absolute inset-[2px] bg-void rounded-lg flex items-center justify-center">
                <span class="text-quantum font-display font-bold text-lg lg:text-xl">C</span>
              </div>
            </div>
            <span class="font-display font-bold text-xl lg:text-2xl tracking-tight text-snow">CHERT</span>
          </a>

          <!-- Desktop Navigation -->
          <div class="hidden lg:flex items-center space-x-12">
            <a href="/technology" class="nav-link">Technology</a>
            <a href="/roadmap" class="nav-link">Roadmap</a>
            <a href="/ecosystem" class="nav-link">Ecosystem</a>
            <a href="/blog" class="nav-link">Blog</a>
            <a href="https://silica.protocol" class="nav-link text-silica-bright hover:text-silica">Silica →</a>
          </div>

          <!-- CTA Buttons -->
          <div class="hidden lg:flex items-center space-x-4">
            <a href="/wallet" class="btn-ghost btn-premium text-sm">Wallet</a>
            <a href="/launch" class="btn-quantum btn-premium text-sm">Launch App</a>
          </div>

          <!-- Mobile Menu Button -->
          <button id="mobile-menu-btn" class="lg:hidden text-pearl p-2" aria-label="Menu">
            <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16"></path>
            </svg>
          </button>
        </div>
      </div>
    </nav>

    <!-- Mobile Menu -->
    <div id="mobile-menu" class="fixed inset-0 z-40 bg-void/98 backdrop-blur-xl hidden lg:hidden">
      <div class="flex flex-col items-center justify-center h-full space-y-8">
        <a href="/technology" class="text-2xl font-display text-pearl hover:text-quantum transition-colors">Technology</a>
        <a href="/roadmap" class="text-2xl font-display text-pearl hover:text-quantum transition-colors">Roadmap</a>
        <a href="/ecosystem" class="text-2xl font-display text-pearl hover:text-quantum transition-colors">Ecosystem</a>
        <a href="/blog" class="text-2xl font-display text-pearl hover:text-quantum transition-colors">Blog</a>
        <a href="https://silica.protocol" class="text-2xl font-display text-silica-bright hover:text-silica transition-colors">Silica →</a>
        <div class="pt-8 flex flex-col space-y-4">
          <a href="/wallet" class="btn-ghost btn-premium">Wallet</a>
          <a href="/launch" class="btn-quantum btn-premium">Launch App</a>
        </div>
      </div>
      <button id="mobile-menu-close" class="absolute top-6 right-6 text-pearl p-2" aria-label="Close">
        <svg class="w-8 h-8" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"></path>
        </svg>
      </button>
    </div>

    <!-- Main Content -->
    <main class="flex-grow">
      <slot />
    </main>

    <!-- Premium Footer -->
    <footer class="relative bg-obsidian border-t border-white/5">
      <!-- Footer Glow -->
      <div class="absolute bottom-0 left-1/2 -translate-x-1/2 w-[600px] h-[300px] bg-quantum/5 blur-[120px] pointer-events-none"></div>
      
      <div class="relative max-w-[1600px] mx-auto px-6 lg:px-12 py-20">
        <div class="grid grid-cols-1 lg:grid-cols-12 gap-12 lg:gap-8">
          <!-- Brand Column -->
          <div class="lg:col-span-4">
            <a href="/" class="flex items-center space-x-3 mb-6">
              <div class="relative w-10 h-10">
                <div class="absolute inset-0 bg-gradient-to-br from-quantum to-quantum-glow rounded-lg"></div>
                <div class="absolute inset-[2px] bg-obsidian rounded-lg flex items-center justify-center">
                  <span class="text-quantum font-display font-bold text-lg">C</span>
                </div>
              </div>
              <span class="font-display font-bold text-2xl tracking-tight text-snow">CHERT</span>
            </a>
            <p class="text-silver text-sm leading-relaxed mb-8 max-w-sm">
              The future of currency. Sub-second finality, million TPS throughput, and post-quantum security. Built for the next century.
            </p>
            <div class="flex items-center space-x-4">
              <a href="https://twitter.com/ChertCoin" class="text-silver hover:text-quantum transition-colors" aria-label="Twitter">
                <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24"><path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-5.214-6.817L4.99 21.75H1.68l7.73-8.835L1.254 2.25H8.08l4.713 6.231zm-1.161 17.52h1.833L7.084 4.126H5.117z"/></svg>
              </a>
              <a href="https://discord.gg/chert" class="text-silver hover:text-quantum transition-colors" aria-label="Discord">
                <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24"><path d="M20.317 4.3698a19.7913 19.7913 0 00-4.8851-1.5152.0741.0741 0 00-.0785.0371c-.211.3753-.4447.8648-.6083 1.2495-1.8447-.2762-3.68-.2762-5.4868 0-.1636-.3933-.4058-.8742-.6177-1.2495a.077.077 0 00-.0785-.037 19.7363 19.7363 0 00-4.8852 1.515.0699.0699 0 00-.0321.0277C.5334 9.0458-.319 13.5799.0992 18.0578a.0824.0824 0 00.0312.0561c2.0528 1.5076 4.0413 2.4228 5.9929 3.0294a.0777.0777 0 00.0842-.0276c.4616-.6304.8731-1.2952 1.226-1.9942a.076.076 0 00-.0416-.1057c-.6528-.2476-1.2743-.5495-1.8722-.8923a.077.077 0 01-.0076-.1277c.1258-.0943.2517-.1923.3718-.2914a.0743.0743 0 01.0776-.0105c3.9278 1.7933 8.18 1.7933 12.0614 0a.0739.0739 0 01.0785.0095c.1202.099.246.1981.3728.2924a.077.077 0 01-.0066.1276 12.2986 12.2986 0 01-1.873.8914.0766.0766 0 00-.0407.1067c.3604.698.7719 1.3628 1.225 1.9932a.076.076 0 00.0842.0286c1.961-.6067 3.9495-1.5219 6.0023-3.0294a.077.077 0 00.0313-.0552c.5004-5.177-.8382-9.6739-3.5485-13.6604a.061.061 0 00-.0312-.0286zM8.02 15.3312c-1.1825 0-2.1569-1.0857-2.1569-2.419 0-1.3332.9555-2.4189 2.157-2.4189 1.2108 0 2.1757 1.0952 2.1568 2.419 0 1.3332-.9555 2.4189-2.1569 2.4189zm7.9748 0c-1.1825 0-2.1569-1.0857-2.1569-2.419 0-1.3332.9554-2.4189 2.1569-2.4189 1.2108 0 2.1757 1.0952 2.1568 2.419 0 1.3332-.946 2.4189-2.1568 2.4189z"/></svg>
              </a>
              <a href="https://github.com/chertcoin" class="text-silver hover:text-quantum transition-colors" aria-label="GitHub">
                <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24"><path d="M12 0c-6.626 0-12 5.373-12 12 0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23.957-.266 1.983-.399 3.003-.404 1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576 4.765-1.589 8.199-6.086 8.199-11.386 0-6.627-5.373-12-12-12z"/></svg>
              </a>
              <a href="https://t.me/chertcoin" class="text-silver hover:text-quantum transition-colors" aria-label="Telegram">
                <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24"><path d="M11.944 0A12 12 0 0 0 0 12a12 12 0 0 0 12 12 12 12 0 0 0 12-12A12 12 0 0 0 12 0a12 12 0 0 0-.056 0zm4.962 7.224c.1-.002.321.023.465.14a.506.506 0 0 1 .171.325c.016.093.036.306.02.472-.18 1.898-.962 6.502-1.36 8.627-.168.9-.499 1.201-.82 1.23-.696.065-1.225-.46-1.9-.902-1.056-.693-1.653-1.124-2.678-1.8-1.185-.78-.417-1.21.258-1.91.177-.184 3.247-2.977 3.307-3.23.007-.032.014-.15-.056-.212s-.174-.041-.249-.024c-.106.024-1.793 1.14-5.061 3.345-.48.33-.913.49-1.302.48-.428-.008-1.252-.241-1.865-.44-.752-.245-1.349-.374-1.297-.789.027-.216.325-.437.893-.663 3.498-1.524 5.83-2.529 6.998-3.014 3.332-1.386 4.025-1.627 4.476-1.635z"/></svg>
              </a>
            </div>
          </div>

          <!-- Navigation Links -->
          <div class="lg:col-span-2">
            <h4 class="font-display font-semibold text-snow text-sm tracking-wider mb-6">PRODUCT</h4>
            <ul class="space-y-4">
              <li><a href="/wallet" class="text-silver text-sm hover:text-pearl transition-colors">Wallet</a></li>
              <li><a href="/explorer" class="text-silver text-sm hover:text-pearl transition-colors">Explorer</a></li>
              <li><a href="/staking" class="text-silver text-sm hover:text-pearl transition-colors">Staking</a></li>
              <li><a href="/bridge" class="text-silver text-sm hover:text-pearl transition-colors">Bridge</a></li>
            </ul>
          </div>

          <div class="lg:col-span-2">
            <h4 class="font-display font-semibold text-snow text-sm tracking-wider mb-6">DEVELOPERS</h4>
            <ul class="space-y-4">
              <li><a href="/docs" class="text-silver text-sm hover:text-pearl transition-colors">Documentation</a></li>
              <li><a href="/api" class="text-silver text-sm hover:text-pearl transition-colors">API Reference</a></li>
              <li><a href="/sdk" class="text-silver text-sm hover:text-pearl transition-colors">SDKs</a></li>
              <li><a href="https://github.com/chertcoin" class="text-silver text-sm hover:text-pearl transition-colors">GitHub</a></li>
            </ul>
          </div>

          <div class="lg:col-span-2">
            <h4 class="font-display font-semibold text-snow text-sm tracking-wider mb-6">NETWORK</h4>
            <ul class="space-y-4">
              <li><a href="/technology" class="text-silver text-sm hover:text-pearl transition-colors">Technology</a></li>
              <li><a href="/validators" class="text-silver text-sm hover:text-pearl transition-colors">Validators</a></li>
              <li><a href="/governance" class="text-silver text-sm hover:text-pearl transition-colors">Governance</a></li>
              <li><a href="/roadmap" class="text-silver text-sm hover:text-pearl transition-colors">Roadmap</a></li>
            </ul>
          </div>

          <div class="lg:col-span-2">
            <h4 class="font-display font-semibold text-snow text-sm tracking-wider mb-6">LEARN</h4>
            <ul class="space-y-4">
              <li><a href="/blog" class="text-silver text-sm hover:text-pearl transition-colors">Blog</a></li>
              <li><a href="/whitepaper" class="text-silver text-sm hover:text-pearl transition-colors">Whitepaper</a></li>
              <li><a href="https://silica.protocol" class="text-silver text-sm hover:text-pearl transition-colors">Silica Protocol</a></li>
              <li><a href="/media" class="text-silver text-sm hover:text-pearl transition-colors">Media Kit</a></li>
            </ul>
          </div>
        </div>

        <!-- Footer Bottom -->
        <div class="mt-16 pt-8 border-t border-white/5 flex flex-col lg:flex-row items-center justify-between">
          <p class="text-silver text-sm">© {new Date().getFullYear()} Chert Coin. All rights reserved.</p>
          <div class="flex items-center space-x-8 mt-4 lg:mt-0">
            <a href="/terms" class="text-silver text-sm hover:text-pearl transition-colors">Terms</a>
            <a href="/privacy" class="text-silver text-sm hover:text-pearl transition-colors">Privacy</a>
            <a href="/disclaimer" class="text-silver text-sm hover:text-pearl transition-colors">Disclaimer</a>
          </div>
        </div>
      </div>
    </footer>

    <!-- Navigation Styles -->
    <style>
      .nav-link {
        font-family: var(--font-display);
        font-size: 0.875rem;
        font-weight: 500;
        color: var(--color-silver);
        letter-spacing: 0.02em;
        position: relative;
        transition: color 0.3s ease;
      }

      .nav-link::after {
        content: '';
        position: absolute;
        bottom: -4px;
        left: 0;
        width: 0;
        height: 1px;
        background: var(--color-quantum);
        transition: width 0.3s ease;
      }

      .nav-link:hover {
        color: var(--color-pearl);
      }

      .nav-link:hover::after {
        width: 100%;
      }

      #main-nav {
        background: transparent;
      }

      #main-nav.scrolled {
        background: rgba(10, 10, 15, 0.9);
        backdrop-filter: blur(20px);
        -webkit-backdrop-filter: blur(20px);
        border-bottom: 1px solid rgba(255, 255, 255, 0.05);
      }
    </style>

    <!-- Scripts -->
    <script>
      // Navigation scroll effect
      const nav = document.getElementById('main-nav');
      window.addEventListener('scroll', () => {
        if (window.scrollY > 50) {
          nav?.classList.add('scrolled');
        } else {
          nav?.classList.remove('scrolled');
        }
      });

      // Mobile menu toggle
      const mobileMenuBtn = document.getElementById('mobile-menu-btn');
      const mobileMenuClose = document.getElementById('mobile-menu-close');
      const mobileMenu = document.getElementById('mobile-menu');

      mobileMenuBtn?.addEventListener('click', () => {
        mobileMenu?.classList.remove('hidden');
        document.body.style.overflow = 'hidden';
      });

      mobileMenuClose?.addEventListener('click', () => {
        mobileMenu?.classList.add('hidden');
        document.body.style.overflow = '';
      });

      // Close mobile menu on link click
      mobileMenu?.querySelectorAll('a').forEach(link => {
        link.addEventListener('click', () => {
          mobileMenu?.classList.add('hidden');
          document.body.style.overflow = '';
        });
      });
    </script>
  </body>
</html>
