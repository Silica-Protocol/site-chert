---
// Blog Layout for Chert Website - Premium Dark Theme
import Layout from './Layout.astro';

interface Props {
  frontmatter: {
    title: string;
    description?: string;
    author?: string;
    date?: string;
    category?: string;
    readingTime?: string;
  };
}

const { frontmatter } = Astro.props;
---

<Layout title={`${frontmatter.title} — Chert`} description={frontmatter.description}>
  <!-- Blog Hero -->
  <section class="relative pt-32 pb-16 overflow-hidden">
    <div class="absolute inset-0 grid-pattern opacity-30"></div>
    <div class="absolute top-1/4 left-1/4 w-[500px] h-[500px] bg-quantum/10 rounded-full blur-[150px]"></div>
    <div class="absolute bottom-1/4 right-1/4 w-[400px] h-[400px] bg-silica/10 rounded-full blur-[120px]"></div>
    
    <div class="relative max-w-4xl mx-auto px-6 lg:px-12">
      <!-- Category Badge -->
      {frontmatter.category && (
        <div class="flex justify-center mb-6">
          <span class="inline-flex items-center px-4 py-1.5 rounded-full text-xs font-semibold tracking-wider uppercase bg-quantum/10 text-quantum border border-quantum/20">
            {frontmatter.category}
          </span>
        </div>
      )}
      
      <!-- Title -->
      <h1 class="font-display text-4xl md:text-5xl lg:text-6xl font-bold text-center text-snow leading-tight mb-8">
        {frontmatter.title}
      </h1>
      
      <!-- Meta -->
      <div class="flex flex-wrap items-center justify-center gap-6 text-silver text-sm">
        {frontmatter.author && (
          <div class="flex items-center gap-2">
            <div class="w-8 h-8 rounded-full bg-gradient-to-br from-quantum to-silica flex items-center justify-center">
              <span class="text-void font-bold text-xs">{frontmatter.author.charAt(0)}</span>
            </div>
            <span>{frontmatter.author}</span>
          </div>
        )}
        {frontmatter.date && (
          <div class="flex items-center gap-2">
            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z"></path>
            </svg>
            <span>{frontmatter.date}</span>
          </div>
        )}
        {frontmatter.readingTime && (
          <div class="flex items-center gap-2">
            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"></path>
            </svg>
            <span>{frontmatter.readingTime}</span>
          </div>
        )}
      </div>
    </div>
  </section>

  <!-- Blog Content -->
  <section class="relative pb-24">
    <div class="max-w-4xl mx-auto px-6 lg:px-12">
      <article class="blog-article">
        <slot />
      </article>
      
      <!-- Back to Blog -->
      <div class="mt-16 pt-8 border-t border-white/10">
        <a href="/blog" class="inline-flex items-center gap-2 text-silver hover:text-quantum transition-colors group">
          <svg class="w-5 h-5 group-hover:-translate-x-1 transition-transform" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7"></path>
          </svg>
          <span>Back to all articles</span>
        </a>
      </div>
    </div>
  </section>
</Layout>

<style is:global>
  .blog-article {
    color: var(--color-pearl);
    line-height: 1.8;
  }
  
  .blog-article h2 {
    font-family: var(--font-display);
    font-size: 1.75rem;
    font-weight: 700;
    color: var(--color-snow);
    margin-top: 3rem;
    margin-bottom: 1.5rem;
    position: relative;
    padding-left: 1.5rem;
  }
  
  .blog-article h2::before {
    content: '';
    position: absolute;
    left: 0;
    top: 0.25rem;
    bottom: 0.25rem;
    width: 4px;
    background: var(--gradient-golden);
    border-radius: 2px;
  }
  
  .blog-article h3 {
    font-family: var(--font-display);
    font-size: 1.25rem;
    font-weight: 600;
    color: var(--color-snow);
    margin-top: 2rem;
    margin-bottom: 1rem;
  }
  
  .blog-article p {
    margin-bottom: 1.5rem;
    color: rgba(232, 232, 240, 0.85);
  }
  
  .blog-article strong {
    color: var(--color-snow);
    font-weight: 600;
  }
  
  .blog-article ul,
  .blog-article ol {
    margin-bottom: 1.5rem;
    padding-left: 1.5rem;
  }
  
  .blog-article li {
    margin-bottom: 0.75rem;
    color: rgba(232, 232, 240, 0.85);
  }
  
  .blog-article li strong {
    color: var(--color-quantum);
  }
  
  .blog-article a {
    color: var(--color-quantum);
    text-decoration: underline;
    text-underline-offset: 2px;
    transition: color 0.2s;
  }
  
  .blog-article a:hover {
    color: var(--color-quantum-bright);
  }
  
  /* Code blocks */
  .blog-article .code-block,
  .blog-article pre {
    background: var(--color-obsidian);
    border: 1px solid rgba(255, 255, 255, 0.08);
    border-radius: 12px;
    padding: 1.5rem;
    margin: 1.5rem 0;
    overflow-x: auto;
  }
  
  .blog-article code {
    font-family: var(--font-mono);
    font-size: 0.9rem;
    color: var(--color-pearl);
  }
  
  .blog-article pre code {
    background: none;
    padding: 0;
  }
  
  .blog-article :not(pre) > code {
    background: rgba(255, 255, 255, 0.05);
    padding: 0.2rem 0.5rem;
    border-radius: 4px;
    font-size: 0.875em;
  }
  
  /* Info boxes */
  .blog-article .info-box,
  .blog-article .tech-details,
  .blog-article .example-box {
    background: rgba(26, 26, 36, 0.6);
    backdrop-filter: blur(20px);
    border: 1px solid rgba(255, 255, 255, 0.08);
    border-radius: 16px;
    padding: 2rem;
    margin: 2rem 0;
  }
  
  .blog-article .info-box h3,
  .blog-article .tech-details h3,
  .blog-article .example-box h4 {
    color: var(--color-quantum);
    margin-top: 0;
    margin-bottom: 1rem;
  }
  
  /* Tables */
  .blog-article table {
    width: 100%;
    border-collapse: collapse;
    margin: 1.5rem 0;
    border-radius: 12px;
    overflow: hidden;
  }
  
  .blog-article th {
    background: var(--color-graphite);
    color: var(--color-snow);
    font-weight: 600;
    text-align: left;
    padding: 1rem;
    border-bottom: 1px solid rgba(255, 255, 255, 0.1);
  }
  
  .blog-article td {
    padding: 1rem;
    border-bottom: 1px solid rgba(255, 255, 255, 0.05);
    color: var(--color-pearl);
  }
  
  .blog-article tr:last-child td {
    border-bottom: none;
  }
  
  .blog-article tr.highlight td {
    background: rgba(251, 191, 36, 0.1);
    color: var(--color-quantum);
    font-weight: 600;
  }
  
  /* CTA sections */
  .blog-article .cta-section {
    background: linear-gradient(135deg, rgba(251, 191, 36, 0.1) 0%, rgba(59, 130, 246, 0.1) 100%);
    border: 1px solid rgba(251, 191, 36, 0.2);
    border-radius: 20px;
    padding: 3rem 2rem;
    text-align: center;
    margin: 3rem 0;
  }
  
  .blog-article .cta-section h2 {
    padding-left: 0;
    text-align: center;
  }
  
  .blog-article .cta-section h2::before {
    display: none;
  }
  
  .blog-article .cta-section p {
    color: var(--color-pearl);
  }
  
  .blog-article .cta-section .conclusion {
    font-size: 1.25rem;
    font-weight: 600;
    color: var(--color-quantum);
  }
  
  /* Benefit cards / grids */
  .blog-article .benefits-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(250px, 1fr));
    gap: 1.5rem;
    margin: 2rem 0;
  }
  
  .blog-article .benefit-card {
    background: rgba(26, 26, 36, 0.6);
    border: 1px solid rgba(255, 255, 255, 0.08);
    border-radius: 16px;
    padding: 1.5rem;
    transition: border-color 0.3s, transform 0.3s;
  }
  
  .blog-article .benefit-card:hover {
    border-color: rgba(251, 191, 36, 0.3);
    transform: translateY(-2px);
  }
  
  .blog-article .benefit-card h3 {
    color: var(--color-quantum);
    margin-top: 0;
    margin-bottom: 0.75rem;
    font-size: 1.1rem;
  }
  
  .blog-article .benefit-card p {
    margin: 0;
    font-size: 0.95rem;
  }
  
  /* Next article links */
  .blog-article .next-article {
    background: var(--color-graphite);
    border-left: 4px solid var(--color-silica);
    border-radius: 0 12px 12px 0;
    padding: 1.5rem 2rem;
    margin-top: 3rem;
  }
  
  .blog-article .next-article p {
    margin: 0;
    color: var(--color-silver);
  }
  
  .blog-article .next-article strong {
    color: var(--color-silica-bright);
  }
  
  /* Comparison table wrapper */
  .blog-article .comparison-table,
  .blog-article .table-container {
    margin: 1.5rem 0;
    overflow-x: auto;
  }
  
  .blog-article .comparison-table h3 {
    color: var(--color-silver);
    font-size: 0.9rem;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    margin-bottom: 1rem;
  }
</style>
